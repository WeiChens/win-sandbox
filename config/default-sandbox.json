{
  "name": "default-sandbox",
  "file_permissions": [
    {
      "pattern": "C:\\Users\\*\\Projects\\**",
      "permission": "inherit"
    },
    {
      "pattern": "C:\\Users\\*\\.cargo\\**",
      "permission": "inherit"
    },
    {
      "pattern": "C:\\Users\\*\\.npm\\**",
      "permission": "inherit"
    },
    {
      "pattern": "C:\\Users\\*\\AppData\\Local\\Temp\\**",
      "permission": "inherit"
    },
    {
      "pattern": "C:\\Users\\*\\*",
      "permission": "read_only"
    },
    {
      "pattern": "C:\\Windows\\**",
      "permission": "read_only"
    },
    {
      "pattern": "C:\\Program Files\\**",
      "permission": "read_only"
    },
    {
      "pattern": "C:\\Program Files (x86)\\**",
      "permission": "read_only"
    },
    {
      "pattern": "C:\\Users\\wei\\Desktop\\test\\**",
      "permission": "read_only"
    }
  ],
  "network_permissions": [
    {
      "host": "*.npmjs.org",
      "port": 443,
      "protocol": "tcp",
      "action": "allow"
    },
    {
      "host": "*.github.com",
      "port": 443,
      "protocol": "tcp",
      "action": "allow"
    },
    {
      "host": "*.githubusercontent.com",
      "port": 443,
      "protocol": "tcp",
      "action": "allow"
    },
    {
      "host": "127.0.0.1",
      "port": 0,
      "protocol": "any",
      "action": "allow"
    },
    {
      "host": "localhost",
      "port": 0,
      "protocol": "any",
      "action": "allow"
    },
    {
      "host": "*",
      "port": 0,
      "protocol": "tcp",
      "action": "allow"
    }
  ],
  "sandbox_root": ".\\sandbox-workdir",
  "shell_path": "C:\\Windows\\System32\\cmd.exe",
  "enable_network_isolation": true,
  "enable_recursive_injection": true,
  "audit_log_dir": ".\\sandbox-logs",
  "verbose_audit": false
}